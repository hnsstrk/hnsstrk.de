# =============================================================================
# .gitignore for hnsstrk.de
# Hugo + HTML/CSS/JS Personal Profile Site
# =============================================================================


# =============================================================================
# Hugo Build Output
# =============================================================================
/public/
/resources/_gen/
/assets/jsconfig.json
.hugo_build.lock


# =============================================================================
# Hugo Deployment
# =============================================================================
.deployment


# =============================================================================
# Node.js
# =============================================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn-integrity
# Uncomment if package-lock.json should not be tracked:
# package-lock.json


# =============================================================================
# Sensitive Data — CRITICAL: Never commit these
# =============================================================================
.env
.env.*
!.env.example
secrets/
*.key
*.pem
*.p12
*.pfx
*.cer
*.crt
credentials.json
service-account.json
*_rsa
*_rsa.pub
*_ed25519
*_ed25519.pub
# Hugo config with embedded secrets (use config.toml for safe, non-secret config)
config.secret.toml
config.private.toml
netlify.toml.secret


# =============================================================================
# API Keys, Tokens, Passwords
# =============================================================================
*.token
*.secret
auth.json
api_keys.*
.netrc


# =============================================================================
# OS-specific
# =============================================================================
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/

# Linux
.directory
.Trash-*


# =============================================================================
# Editor & IDE
# =============================================================================
# Visual Studio Code
.vscode/
!.vscode/extensions.json

# JetBrains IDEs (IntelliJ, WebStorm, etc.)
.idea/
*.iml
*.iws
*.ipr

# Vim / Neovim
*.swp
*.swo
*~
.netrwhist
Session.vim
.vim/

# Emacs
*#
.#*
\#*#


# =============================================================================
# Logs
# =============================================================================
*.log
logs/
npm-debug.log
hugo-server.log


# =============================================================================
# Temporary & Cache Files
# =============================================================================
tmp/
temp/
.temp/
.tmp/
.cache/
*.bak
*.orig
*.rej


# =============================================================================
# Content Drafts — erst nach Review committen
# =============================================================================
content/blog/


# =============================================================================
# Claude Code
# =============================================================================
# .claude/ directory is intentionally tracked (skills, CLAUDE.md context)
# but sensitive settings should not be committed:
.claude/settings.json
.claude/settings.local.json
# Note: .claude/projects/ should NOT be ignored — tracked intentionally if present
